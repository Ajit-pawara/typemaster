---
import { getUserFromRequest } from '../lib/auth';

const user = await getUserFromRequest(Astro.request);
const { pathname } = Astro.url;

const isActive = (path: string) => {
  if (path === '/' && pathname === '/') return true;
  if (path !== '/' && pathname.startsWith(path)) return true;
  return false;
};
---

<nav class="sticky top-0 z-40 w-full h-[64px] border-b border-hairline bg-canvas/80 backdrop-blur-md flex items-center justify-between px-6 md:px-12">
  <!-- Left: Logo -->
  <div class="flex items-center space-x-6">
    <a href="/" class="flex items-center space-x-1 font-semibold text-lg tracking-tight select-none">
      <span>TypeMaster</span>
      <span class="text-[10px] text-brand-cyan bg-brand-cyan-soft px-1.5 py-0.2 rounded border border-brand-cyan/20 font-mono">.dev</span>
    </a>
    
    <!-- Center: Links (Desktop) -->
    <div class="hidden md:flex items-center space-x-2">
      <a 
        href="/" 
        class={`px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${
          isActive('/') ? 'text-ink bg-canvas-soft-2 font-semibold' : 'text-body hover:text-ink'
        }`}
      >
        Practice
      </a>
      <a 
        href="/challenge" 
        class={`px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${
          isActive('/challenge') ? 'text-ink bg-canvas-soft-2 font-semibold' : 'text-body hover:text-ink'
        }`}
      >
        Daily Challenge
      </a>
      <a 
        href="/racer" 
        class={`px-3 py-1.5 rounded-full text-xs font-semibold transition-all border ${
          isActive('/racer') 
            ? 'text-brand-cyan bg-brand-cyan-soft border-brand-cyan/30 shadow-sm' 
            : 'text-brand-cyan bg-brand-cyan-soft/10 border-brand-cyan/10 hover:bg-brand-cyan-soft/30 hover:border-brand-cyan/30'
        }`}
      >
        🏎️ TypeRacer
      </a>
      <a 
        href="/leaderboards" 
        class={`px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${
          isActive('/leaderboards') ? 'text-ink bg-canvas-soft-2 font-semibold' : 'text-body hover:text-ink'
        }`}
      >
        Leaderboards
      </a>
      {user && (
        <a 
          href="/dashboard" 
          class={`px-3 py-1.5 rounded-full text-xs font-medium transition-colors ${
            isActive('/dashboard') ? 'text-ink bg-canvas-soft-2 font-semibold' : 'text-body hover:text-ink'
          }`}
        >
          Dashboard
        </a>
      )}
    </div>
  </div>

  <!-- Right: Auth actions / Profile -->
  <div class="flex items-center space-x-4">
    {user ? (
      <div class="flex items-center space-x-4">
        {user.streak > 0 && (
          <div class="flex items-center space-x-1 text-xs font-mono text-warning" title={`${user.streak}-day typing streak!`}>
            <span>🔥</span>
            <span class="font-bold">{user.streak}</span>
          </div>
        )}
        <a 
          href={`/profile/${user.username}`} 
          class="text-xs font-medium text-body hover:text-ink flex items-center space-x-1.5 border border-hairline px-3 py-1 bg-canvas-soft rounded-full hover:border-hairline-strong transition-all"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-brand-cyan"></span>
          <span>{user.username}</span>
        </a>
        <a 
          href="/logout" 
          class="text-xs font-medium text-mute hover:text-error transition-colors"
        >
          Logout
        </a>
      </div>
    ) : (
      <div class="flex items-center space-x-2">
        <a 
          href="/login" 
          class="px-3 py-1.5 text-xs font-medium text-body hover:text-ink transition-colors rounded-md"
        >
          Log In
        </a>
        <a 
          href="/register" 
          class="px-3 py-1.5 bg-ink text-canvas hover:opacity-90 transition-opacity text-xs font-semibold rounded-md shadow-level-1"
        >
          Sign Up
        </a>
      </div>
    )}
  </div>
</nav>
