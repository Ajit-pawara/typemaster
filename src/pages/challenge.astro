---
import Layout from '../layouts/Layout.astro';
import TypingTest from '../components/TypingTest';
import AdUnit from '../components/AdUnit';
import { getUserFromRequest } from '../lib/auth';
import { getDb } from '../lib/db';
import { ObjectId } from 'mongodb';

// Authenticate user
const user = await getUserFromRequest(Astro.request);

const db = await getDb();
const todayStr = new Date().toISOString().split('T')[0];

// Fetch or generate today's challenge
let challenge = await db.collection('daily_challenges').findOne({ date: todayStr });
if (!challenge) {
  const defaultTexts = [
    "To write clean code is to understand the balance between complexity and elegance. Every variable must have meaning.",
    "The standard you walk past is the standard you accept in your organization. Choose your actions carefully.",
    "A smooth sea never made a skilled sailor, and endless practice makes typing perfect and fluid.",
    "Optimism is the faith that leads to achievement. Nothing can be done without hope, practice, and confidence.",
    "Great works are performed not by strength but by perseverance. Train your fingers on the keyboard every day."
  ];
  const text = defaultTexts[Math.floor(Math.random() * defaultTexts.length)];
  const newChallenge = { date: todayStr, text, createdAt: new Date() };
  const insertRes = await db.collection('daily_challenges').insertOne(newChallenge);
  challenge = { ...newChallenge, _id: insertRes.insertedId };
}

// Fetch today's challenge leaderboard
const leaderboard = await db.collection('challenge_participants')
  .find({ challengeId: challenge._id })
  .sort({ wpm: -1, accuracy: -1 })
  .limit(20)
  .toArray();

// Check if user has already participated today
let userScore = null;
if (user) {
  userScore = await db.collection('challenge_participants').findOne({
    challengeId: challenge._id,
    userId: new ObjectId(user.id)
  });
}
---

<Layout title="Daily Challenge — TypeMaster" description="Participate in today's typing challenge and climb the leaderboard.">
  <div class="space-y-8">
    <!-- Page Header -->
    <div class="border-b border-hairline pb-6">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <span class="text-[10px] font-mono text-brand-violet uppercase tracking-widest border border-brand-violet/20 px-2 py-0.5 rounded bg-brand-violet-soft mb-2 inline-block">
            Streak Booster
          </span>
          <h1 class="text-2xl font-bold text-ink">Daily Typing Challenge</h1>
          <p class="text-xs text-body">New paragraph every day. Maintain your typing streak and compete globally.</p>
        </div>
        {user && (
          <div class="flex items-center space-x-1 border border-hairline px-3 py-1.5 bg-canvas-soft rounded-full text-xs font-mono text-warning">
            <span>🔥</span>
            <span class="font-bold">Current Streak: {user.streak} day{user.streak !== 1 ? 's' : ''}</span>
          </div>
        )}
      </div>
    </div>

    <!-- Main Split Grid (Test on left, Leaderboard on right) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      <!-- Test Column -->
      <div class="lg:col-span-2 space-y-6">
        {userScore && (
          <div class="p-4 border border-brand-cyan/20 bg-brand-cyan-soft rounded-lg text-xs text-brand-cyan flex items-center justify-between">
            <div>
              🎉 You have submitted a score for today's challenge!
              Your best score is <span class="font-bold">{userScore.wpm} WPM</span> with <span class="font-bold">{userScore.accuracy}% Accuracy</span>.
            </div>
            <div class="font-mono text-[10px] text-mute">You can retry to increase your WPM!</div>
          </div>
        )}
        
        <!-- Typing Engine -->
        <TypingTest 
          user={user} 
          isChallenge={true} 
          challengeText={challenge.text} 
          challengeDuration={60} 
          client:load 
        />
      </div>

      <!-- Leaderboard Column -->
      <div class="p-6 border border-hairline bg-canvas-soft rounded-lg shadow-level-2 lg:col-span-1">
        <h3 class="text-sm font-semibold text-ink mb-1">Today's Leaderboard</h3>
        <p class="text-[10px] text-body mb-4">Top scores for the challenge on {new Date().toLocaleDateString()}.</p>

        {leaderboard.length === 0 ? (
          <div class="p-8 border border-dashed border-hairline rounded text-center text-xs text-mute font-mono">
            No submissions yet. Be the first to type!
          </div>
        ) : (
          <div class="space-y-2 max-h-[360px] overflow-y-auto pr-1">
            {leaderboard.map((item, index) => {
              const isCurrentUser = user && item.userId.toString() === user.id;
              let rankColor = 'text-mute';
              if (index === 0) rankColor = 'text-amber-400 font-bold';
              else if (index === 1) rankColor = 'text-slate-300 font-bold';
              else if (index === 2) rankColor = 'text-amber-600 font-bold';

              return (
                <div class={`flex items-center justify-between p-2.5 rounded-md border text-xs ${
                  isCurrentUser 
                    ? 'bg-brand-violet-soft border-brand-violet/30' 
                    : 'bg-canvas-soft-2 border-hairline'
                }`}>
                  <div class="flex items-center space-x-3">
                    <span class={`w-5 font-mono text-center ${rankColor}`}>{index + 1}</span>
                    <span class={`font-semibold ${isCurrentUser ? 'text-ink' : 'text-body'}`}>
                      {item.username}
                    </span>
                  </div>
                  <div class="text-right font-mono">
                    <span class="text-ink font-bold">{item.wpm}</span> <span class="text-mute text-[10px]">WPM</span>
                    <span class="text-mute mx-1.5">•</span>
                    <span class="text-body font-semibold">{item.accuracy}%</span>
                  </div>
                </div>
              );
            })}
          </div>
        )}

        <div class="mt-6 pt-4 border-t border-hairline">
          <AdUnit type="sidebar" />
        </div>
      </div>
    </div>
  </div>
</Layout>
