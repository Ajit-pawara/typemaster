---
import Layout from '../layouts/Layout.astro';
import TypingTest from '../components/TypingTest';
import AdUnit from '../components/AdUnit';
import { getUserFromRequest } from '../lib/auth';

const user = await getUserFromRequest(Astro.request);
---

<Layout>
  <!-- Hero Headline and Atmospheric Mesh Background -->
  <div class="relative py-12 text-center max-w-3xl mx-auto overflow-hidden">
    <!-- Spotlight effects -->
    <div class="absolute top-0 left-1/4 w-72 h-72 bg-brand-cyan/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-brand-violet/10 rounded-full blur-3xl -z-10 pointer-events-none"></div>
    
    <span class="text-[10px] font-mono text-brand-cyan uppercase tracking-widest border border-brand-cyan/20 px-2 py-0.5 rounded bg-brand-cyan-soft mb-4 inline-block">
      Optimize Your Typing Speed
    </span>
    
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink leading-tight select-none">
      Master your keyboard. <br class="hidden md:inline" />
      Build muscle memory.
    </h1>
    
    <p class="text-sm text-body max-w-lg mx-auto mt-4 leading-relaxed">
      A minimalist, developer-focused typing test engine optimized for speed and accuracy. Practice coding snippets, numbers, symbols, and core vocabulary.
    </p>
  </div>

  <!-- Main Section Layout (Test Area + Sidebar Ads) -->
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 items-start mt-4">
    <div class="lg:col-span-3">
      <!-- Typing engine island -->
      <TypingTest user={user} client:load />
    </div>
    
    <!-- Sidebar Content (Desktop only) -->
    <div class="hidden lg:flex flex-col space-y-6 lg:col-span-1 items-center justify-start sticky top-[80px]">
      <div class="w-full p-4 border border-hairline bg-canvas-soft rounded-lg text-center shadow-level-1">
        <h3 class="text-xs font-mono text-mute uppercase tracking-widest mb-3">Typing tips</h3>
        <ul class="text-[11px] text-body text-left space-y-2 list-disc list-inside">
          <li>Keep your wrists flat and elevated above the keyboard.</li>
          <li>Focus on 100% accuracy first; speed is a byproduct.</li>
          <li>Use coding mode to practice JavaScript and TypeScript syntax!</li>
        </ul>
      </div>
      
      <AdUnit type="sidebar" />
    </div>
  </div>
</Layout>
